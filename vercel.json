{
  "services": {
    "frontend": {
      "root": ".",
      "framework": "vite",
      "buildCommand": "npm run build",
      "outputDirectory": "dist",
      "installCommand": "npm install"
    },
    "backend": {
      "root": "backend",
      "framework": "express",
      "entrypoint": "server.js",
      "installCommand": "npm install"
    }
  },
  "rewrites": [
    {
      "source": "/api",
      "destination": { "service": "backend", "path": "/" }
    },
    {
      "source": "/api/(.*)",
      "destination": { "service": "backend", "path": "/$1" }
    },
    {
      "source": "/(.*)",
      "destination": { "service": "frontend" }
    }
  ]
}
