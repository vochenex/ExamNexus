# Backend — copy to backend/.env
# Get values from Supabase → Project Settings → API

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Required for admin password reset and privileged server operations.
# Never expose this key in the frontend or commit it to git.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Recommended for faculty auth when Supabase API is slow or unreachable.
# Supabase Dashboard → Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Assessment AI (Google Gemini) ---
# Get a free API key: https://aistudio.google.com/apikey

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Optional: Gemini timeouts in milliseconds (defaults: 300000 prompt, 600000 document)
# AI_CHAT_TIMEOUT_MS=300000
# AI_DOCUMENT_TIMEOUT_MS=600000

# Free tier is ~20 requests/min — space out multi-question generation (defaults: 4000ms, 5 per chunk)
# GEMINI_BATCH_DELAY_MS=4000
# GEMINI_CHUNK_SIZE=5

# Push notifications (FCM HTTP v1 — recommended for new Firebase projects)
# Firebase Console → Project settings → Service accounts → Generate new private key
# Save the JSON file outside git, e.g. backend/firebase-service-account.json
# FCM_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# FCM_PROJECT_ID=examnexus-9d77a

# Legacy server key (deprecated; unavailable on most new Firebase projects)
# FCM_SERVER_KEY=your-fcm-server-key

# Web Push (desktop PWA + iOS Add to Home Screen)
# Generate with: node -e "console.log(require('web-push').generateVAPIDKeys())"
# Then set both keys on Vercel (Production) and in backend/.env locally.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:support@examnexus.app
# WEBSITE_URL=https://exam-nexus-eta.vercel.app

# Optional: direct DB scripts (backend/scripts/setupEnrollment.js)
# SUPABASE_DB_PASSWORD=your-db-password

# --- Vercel ---
# Set the same keys in the Vercel project Environment Variables (Production).
# For FCM on Vercel, paste the full service-account JSON as one line:
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FCM_PROJECT_ID=examnexus-9d77a
# Also set VAPID_PUBLIC_KEY + VAPID_PRIVATE_KEY for iPhone Home Screen push.
