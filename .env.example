# Frontend (Vite) — copy to .env in the project root
# Get values from Supabase → Project Settings → API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend URL
# Local: leave unset or use http://localhost:5000
# Vercel web: leave unset (defaults to /api) OR set explicitly:
# VITE_API_BASE_URL=/api
# Production Android APK (users on any network):
# VITE_API_BASE_URL=https://your-app.vercel.app/api
# Local APK on same Wi‑Fi: `npm run cap:apk` rewrites localhost → LAN IP

# Public website URL for the deployed web app. In the mobile app, students who
# tap "Take Assessment" are redirected to open the exam on this website.
VITE_WEBSITE_URL=https://your-app.vercel.app

# Do NOT put the service role key in the frontend. Use backend/.env / Vercel env instead.
