# Frontend (Vite) — copy to .env in the project root
# Get values from Supabase → Project Settings → API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: backend URL when not using the default (http://localhost:5000)
# The backend auto-updates this if port 5000 is busy and it starts on 5001, etc.
# VITE_API_BASE_URL=http://localhost:5000

# Public website URL for the deployed web app. In the mobile app, students who
# tap "Take Assessment" are redirected to open the exam on this website.
VITE_WEBSITE_URL=https://examnexus.app

# Do NOT put the service role key in the frontend. Use backend/.env instead.
