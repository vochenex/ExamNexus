# Frontend (Vite) — copy to .env in the project root
# Get values from Supabase → Project Settings → API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: backend URL when not using the default (http://localhost:5000)
# VITE_API_BASE_URL=http://localhost:5000

# Do NOT put the service role key in the frontend. Use backend/.env instead.
